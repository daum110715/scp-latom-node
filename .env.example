# ─── SCP Docs — Frontend Environment Variables ───────────────
# Copy this file to .env and adjust values for your environment.
# All variables prefixed with VITE_ are exposed to the browser.

# Backend API base URL (no trailing slash).
# Default: https://api.scp.lat
VITE_API_BASE=https://api.scp.lat

# API version prefix. Set to 'v1' once the backend deploys /api/v1/* routes.
# Leave empty to match the current unversioned backend at /api/*.
VITE_API_VERSION=

# Log level: debug | info | warn | error
# Default: warn in production, debug in development
VITE_LOG_LEVEL=
