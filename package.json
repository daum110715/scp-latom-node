{
  "name": "scp-docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,css,json}\"",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "admin:dev": "cd admin && npm run dev",
    "admin:build": "cd admin && npm run build",
    "admin:typecheck": "cd admin && npm run typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "admin/**/*.{ts,tsx,vue}": [
      "sh -c 'cd admin && npx eslint --fix \"${0#admin/}\"'",
      "prettier --write"
    ],
    "worker/**/*.{ts,tsx,json}": [
      "sh -c 'cd worker && npx eslint --fix \"${0#worker/}\"'",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  }
}
